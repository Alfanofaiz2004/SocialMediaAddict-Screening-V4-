datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

model User {
  UserID   Int                @id @default(autoincrement())
  Username String             @unique
  results  AssessmentResult[]
}

model AssessmentResult {
  UserID_hash        String   @id @default(uuid())
  userId             Int
  user               User     @relation(fields: [userId], references: [UserID], onDelete: Cascade)
  date               DateTime @default(now())
  zone               String
  svasTotal          Int
  q1_salience        Int
  q2_mood            Int
  q3_tolerance       Int
  q4_withdrawal      Int
  q5_conflict        Int
  q6_relapse         Int
  socialMediaHours   Float
  sleepHours         Float
  productivityImpact Int
  instagramHours     Float
  tiktokHours        Float
  youtubeHours       Float
  twitterHours       Float
}
