datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model AssessmentResult {
  id             String   @id @default(uuid())
  respondentName String
  date           DateTime @default(now())
  overallScore   String
  zone           String
  svasTotal      Int
  rawInput       Json
  rawResult      Json
}
